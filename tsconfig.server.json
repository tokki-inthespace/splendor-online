{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist-server",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": true
  },
  "include": [
    "server/**/*",
    "src/types/game.ts",
    "src/game/gameLogic.ts",
    "src/game/cardData.ts",
    "src/protocol.ts"
  ]
}
